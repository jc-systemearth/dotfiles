# =============================================================================
# WORK BREWFILE - Work-related tools and apps
# =============================================================================
# Install with: brew bundle --file=Brewfile.work
# =============================================================================

# Taps
tap "supabase/tap"

# -----------------------------------------------------------------------------
# CLI: Containers
# -----------------------------------------------------------------------------
brew "docker"
brew "docker-compose"

# -----------------------------------------------------------------------------
# CLI: Database
# -----------------------------------------------------------------------------
brew "supabase"

# -----------------------------------------------------------------------------
# CLI: Cloud & infrastructure
# -----------------------------------------------------------------------------
brew "pulumi"

# -----------------------------------------------------------------------------
# GUI: Cloud tools
# -----------------------------------------------------------------------------
cask "gcloud-cli"

# -----------------------------------------------------------------------------
# GUI: Editors
# -----------------------------------------------------------------------------
cask "visual-studio-code"

# -----------------------------------------------------------------------------
# GUI: Version control
# -----------------------------------------------------------------------------
cask "github"

# -----------------------------------------------------------------------------
# GUI: Communication (work)
# -----------------------------------------------------------------------------
cask "slack"
cask "microsoft-teams"

# -----------------------------------------------------------------------------
# GUI: Meetings
# -----------------------------------------------------------------------------
cask "granola"

# -----------------------------------------------------------------------------
# GUI: Microsoft Office
# -----------------------------------------------------------------------------
cask "microsoft-word"
cask "microsoft-powerpoint"
cask "microsoft-excel"

# -----------------------------------------------------------------------------
# GUI: API tools
# -----------------------------------------------------------------------------
cask "postman"

